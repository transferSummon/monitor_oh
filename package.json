{
  "name": "olympic-holiday-monitor",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "scrape": "npm --workspace scraper-engine run scrape --",
    "scrape:build": "npm --workspace scraper-engine run build",
    "scrape:test": "npm --workspace scraper-engine run test",
    "scrape:inspect": "npm --workspace scraper-engine run scrape -- inspect --latest",
    "worker": "npm --workspace @olympic/worker run worker --",
    "worker:all": "npm run worker -- run-all",
    "worker:offers": "npm run worker -- run --module offers",
    "worker:marketing": "npm run worker -- run --module marketing",
    "worker:ads": "npm run worker -- run --module ads",
    "worker:railway": "npm run worker:all",
    "worker:build": "npm --workspace @olympic/worker run build",
    "db:build": "npm --workspace @olympic/db run build",
    "contracts:build": "npm --workspace @olympic/contracts run build"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.99.2",
    "autoprefixer": "^10.4.20",
    "cheerio": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.44.2",
    "lucide-react": "^1.8.0",
    "next": "^15.2.0",
    "playwright": "^1.52.0",
    "postcss": "^8.4.49",
    "postgres": "^3.4.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "typescript": "^5.7.2"
  }
}
